{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-term-memory.local/schemas/semantic-memory.schema.json",
  "title": "Semantic Memory",
  "type": "object",
  "required": [
    "memory_id",
    "type",
    "gist",
    "scope_type",
    "scope_value",
    "confidence",
    "importance",
    "status",
    "decay_state",
    "created_at",
    "updated_at",
    "last_confirmed_at",
    "evidence_refs",
    "derived_from",
    "conflicts_with"
  ],
  "additionalProperties": false,
  "properties": {
    "memory_id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "$ref": "./candidate-memory.schema.json#/$defs/memoryType"
    },
    "gist": {
      "type": "string",
      "minLength": 1
    },
    "scope_type": {
      "$ref": "./candidate-memory.schema.json#/$defs/scopeType"
    },
    "scope_value": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "$ref": "./candidate-memory.schema.json#/$defs/score"
    },
    "importance": {
      "$ref": "./candidate-memory.schema.json#/$defs/score"
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "decay_state": {
      "$ref": "#/$defs/decayState"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_confirmed_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./candidate-memory.schema.json#/$defs/evidenceRef"
      }
    },
    "derived_from": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/derivedFromRef"
      }
    },
    "conflicts_with": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conflictRef"
      }
    },
    "source_trust_level": {
      "$ref": "./candidate-memory.schema.json#/$defs/sourceTrustLevel"
    },
    "sensitivity": {
      "$ref": "./candidate-memory.schema.json#/$defs/sensitivity"
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "boundary_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "promoted",
        "stable",
        "fading",
        "archived",
        "deprecated",
        "deleted"
      ]
    },
    "decayState": {
      "type": "string",
      "enum": [
        "stable",
        "fading",
        "archived"
      ]
    },
    "derivedFromRef": {
      "type": "object",
      "required": [
        "source_kind",
        "source_id",
        "relation_type"
      ],
      "additionalProperties": false,
      "properties": {
        "source_kind": {
          "type": "string",
          "enum": [
            "candidate",
            "semantic",
            "episodic",
            "session_distillation"
          ]
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "relation_type": {
          "type": "string",
          "enum": [
            "promoted_from",
            "merged_from",
            "refined_from",
            "distilled_from"
          ]
        }
      }
    },
    "conflictRef": {
      "type": "object",
      "required": [
        "memory_id",
        "conflict_status",
        "note"
      ],
      "additionalProperties": false,
      "properties": {
        "memory_id": {
          "type": "string",
          "minLength": 1
        },
        "conflict_status": {
          "type": "string",
          "enum": [
            "active",
            "resolved",
            "deprecated"
          ]
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
