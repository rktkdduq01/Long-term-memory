{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-term-memory.local/schemas/memory-candidate.schema.json",
  "title": "Memory Candidate",
  "type": "object",
  "required": [
    "candidate_id",
    "target_kind",
    "memory_type",
    "gist",
    "fact_or_inference",
    "status",
    "scope_type",
    "scope_value",
    "confidence",
    "future_usefulness",
    "created_at",
    "evidence_refs",
    "source_trust_level",
    "sensitivity",
    "why_keep",
    "supersedes",
    "conflicts"
  ],
  "additionalProperties": false,
  "properties": {
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "target_kind": {
      "$ref": "./memory.schema.json#/$defs/memoryKind"
    },
    "memory_type": {
      "$ref": "./memory.schema.json#/$defs/memoryType"
    },
    "gist": {
      "type": "string",
      "minLength": 1
    },
    "fact_or_inference": {
      "$ref": "./memory.schema.json#/$defs/factOrInference"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ]
    },
    "scope_type": {
      "$ref": "./memory.schema.json#/$defs/scopeType"
    },
    "scope_value": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "$ref": "./memory.schema.json#/$defs/score"
    },
    "future_usefulness": {
      "$ref": "./memory.schema.json#/$defs/score"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./memory.schema.json#/$defs/evidenceRef"
      }
    },
    "source_trust_level": {
      "$ref": "./memory.schema.json#/$defs/sourceTrustLevel"
    },
    "sensitivity": {
      "$ref": "./memory.schema.json#/$defs/sensitivity"
    },
    "why_keep": {
      "type": "string",
      "minLength": 1
    },
    "uncertainty_note": {
      "type": "string",
      "minLength": 1
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "conflicts": {
      "type": "array",
      "items": {
        "$ref": "./memory.schema.json#/$defs/conflictRef"
      }
    }
  }
}
