{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-term-memory.local/schemas/memory-selection.schema.json",
  "title": "Memory Selection",
  "type": "object",
  "required": [
    "selected_semantic_ids",
    "selected_episodic_ids",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "selected_semantic_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "selected_episodic_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/selectionNote"
      }
    }
  },
  "$defs": {
    "selectionNote": {
      "type": "object",
      "required": [
        "memory_id",
        "memory_kind",
        "why_it_matters_now",
        "relevance_to_task",
        "confidence",
        "evidence_refs"
      ],
      "additionalProperties": false,
      "properties": {
        "memory_id": {
          "type": "string",
          "minLength": 1
        },
        "memory_kind": {
          "type": "string",
          "enum": [
            "semantic",
            "episodic"
          ]
        },
        "why_it_matters_now": {
          "type": "string",
          "minLength": 1
        },
        "relevance_to_task": {
          "$ref": "./candidate-memory.schema.json#/$defs/score"
        },
        "confidence": {
          "$ref": "./candidate-memory.schema.json#/$defs/score"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "./candidate-memory.schema.json#/$defs/evidenceRef"
          }
        }
      }
    }
  }
}
