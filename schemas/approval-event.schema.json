{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-term-memory.local/schemas/approval-event.schema.json",
  "title": "Approval Event",
  "type": "object",
  "required": [
    "event_id",
    "action",
    "candidate_id",
    "memory_id",
    "decided_at",
    "decided_by",
    "reason",
    "evidence_refs"
  ],
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "enum": [
        "candidate_generated",
        "candidate_approved",
        "candidate_rejected",
        "memory_superseded"
      ]
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "memory_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "decided_at": {
      "type": "string",
      "format": "date-time"
    },
    "decided_by": {
      "type": "string",
      "enum": [
        "user",
        "runtime"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./memory.schema.json#/$defs/evidenceRef"
      }
    }
  }
}
