{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-term-memory.local/schemas/promotion-decision.schema.json",
  "title": "Promotion Decision",
  "type": "object",
  "required": [
    "decisions"
  ],
  "additionalProperties": false,
  "properties": {
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      }
    }
  },
  "$defs": {
    "decisionType": {
      "type": "string",
      "enum": [
        "promote",
        "promote_tentative",
        "hold_for_more_evidence",
        "reject",
        "merge_with_existing",
        "update_existing",
        "flag_conflict"
      ]
    },
    "scoredDimension": {
      "type": "object",
      "required": [
        "score",
        "rationale"
      ],
      "additionalProperties": false,
      "properties": {
        "score": {
          "$ref": "./candidate-memory.schema.json#/$defs/score"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scores": {
      "type": "object",
      "required": [
        "reuse_frequency",
        "decision_impact",
        "confidence",
        "novelty_or_exceptionality",
        "explicit_user_signal",
        "long_horizon_relevance"
      ],
      "additionalProperties": false,
      "properties": {
        "reuse_frequency": {
          "$ref": "#/$defs/scoredDimension"
        },
        "decision_impact": {
          "$ref": "#/$defs/scoredDimension"
        },
        "confidence": {
          "$ref": "#/$defs/scoredDimension"
        },
        "novelty_or_exceptionality": {
          "$ref": "#/$defs/scoredDimension"
        },
        "explicit_user_signal": {
          "$ref": "#/$defs/scoredDimension"
        },
        "long_horizon_relevance": {
          "$ref": "#/$defs/scoredDimension"
        }
      }
    },
    "decision": {
      "type": "object",
      "required": [
        "candidate_id",
        "candidate_gist",
        "recommended_decision",
        "resulting_status",
        "reason",
        "scores",
        "target_memory_id",
        "evidence_refs"
      ],
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "candidate_gist": {
          "type": "string",
          "minLength": 1
        },
        "recommended_decision": {
          "$ref": "#/$defs/decisionType"
        },
        "resulting_status": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "held",
            "promoted",
            null
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "scores": {
          "$ref": "#/$defs/scores"
        },
        "target_memory_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "./candidate-memory.schema.json#/$defs/evidenceRef"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "recommended_decision": {
                "enum": [
                  "hold_for_more_evidence",
                  "flag_conflict"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "resulting_status": {
                "const": "held"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "recommended_decision": {
                "enum": [
                  "promote",
                  "promote_tentative",
                  "merge_with_existing",
                  "update_existing"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "resulting_status": {
                "const": "promoted"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "recommended_decision": {
                "const": "reject"
              }
            }
          },
          "then": {
            "properties": {
              "resulting_status": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "recommended_decision": {
                "enum": [
                  "merge_with_existing",
                  "update_existing"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "target_memory_id": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "else": {
            "if": {
              "properties": {
                "recommended_decision": {
                  "enum": [
                    "promote",
                    "promote_tentative",
                    "hold_for_more_evidence",
                    "reject"
                  ]
                }
              }
            },
            "then": {
              "properties": {
                "target_memory_id": {
                  "type": "null"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "recommended_decision": {
                "const": "flag_conflict"
              }
            }
          },
          "then": {
            "properties": {
              "target_memory_id": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              }
            }
          }
        }
      ]
    }
  }
}
