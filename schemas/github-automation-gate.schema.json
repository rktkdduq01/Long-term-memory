{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-term-memory.local/schemas/github-automation-gate.schema.json",
  "title": "GitHub Automation Gate",
  "type": "object",
  "required": [
    "allow_commit",
    "allow_push",
    "allow_pr_creation",
    "requires_human_review",
    "risk_level",
    "reason",
    "required_next_steps"
  ],
  "additionalProperties": false,
  "properties": {
    "allow_commit": {
      "type": "boolean"
    },
    "allow_push": {
      "type": "boolean"
    },
    "allow_pr_creation": {
      "type": "boolean"
    },
    "requires_human_review": {
      "type": "boolean"
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "required_next_steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
