{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-term-memory.local/schemas/candidate-memory.schema.json",
  "title": "Candidate Memory",
  "type": "object",
  "required": [
    "candidate_id",
    "type",
    "gist",
    "fact_or_inference",
    "status",
    "scope_type",
    "scope_value",
    "confidence",
    "future_usefulness",
    "evidence_refs",
    "source_trust_level",
    "sensitivity",
    "why_keep"
  ],
  "additionalProperties": false,
  "properties": {
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "$ref": "#/$defs/memoryType"
    },
    "gist": {
      "type": "string",
      "minLength": 1
    },
    "fact_or_inference": {
      "$ref": "#/$defs/factOrInference"
    },
    "status": {
      "$ref": "#/$defs/candidateStatus"
    },
    "scope_type": {
      "$ref": "#/$defs/scopeType"
    },
    "scope_value": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "$ref": "#/$defs/score"
    },
    "future_usefulness": {
      "$ref": "#/$defs/score"
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidenceRef"
      }
    },
    "source_trust_level": {
      "$ref": "#/$defs/sourceTrustLevel"
    },
    "sensitivity": {
      "$ref": "#/$defs/sensitivity"
    },
    "why_keep": {
      "type": "string",
      "minLength": 1
    },
    "uncertainty_note": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "memoryType": {
      "type": "string",
      "enum": [
        "user_preference",
        "repo_rule",
        "project_constraint",
        "failure_lesson",
        "success_pattern",
        "exception_rule",
        "approval_boundary",
        "unresolved_risk"
      ]
    },
    "factOrInference": {
      "type": "string",
      "enum": [
        "fact",
        "inference"
      ]
    },
    "candidateStatus": {
      "type": "string",
      "enum": [
        "candidate",
        "held"
      ]
    },
    "scopeType": {
      "type": "string",
      "enum": [
        "global_user",
        "repo",
        "branch",
        "directory",
        "file",
        "task_type",
        "session"
      ]
    },
    "sourceType": {
      "type": "string",
      "enum": [
        "user_message",
        "agent_message",
        "tool_result",
        "file",
        "test_result",
        "ci_log",
        "repo_config",
        "manual_review"
      ]
    },
    "sourceTrustLevel": {
      "type": "string",
      "enum": [
        "trusted",
        "partially_trusted",
        "untrusted"
      ]
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "sensitive",
        "restricted"
      ]
    },
    "evidenceRef": {
      "type": "object",
      "required": [
        "source_type",
        "source_id",
        "quote_or_summary",
        "observed_at",
        "trust_level"
      ],
      "additionalProperties": false,
      "properties": {
        "source_type": {
          "$ref": "#/$defs/sourceType"
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "quote_or_summary": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "trust_level": {
          "$ref": "#/$defs/sourceTrustLevel"
        }
      }
    }
  }
}
