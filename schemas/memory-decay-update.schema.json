{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-term-memory.local/schemas/memory-decay-update.schema.json",
  "title": "Memory Decay Update",
  "type": "object",
  "required": [
    "updates"
  ],
  "additionalProperties": false,
  "properties": {
    "updates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/update"
      }
    }
  },
  "$defs": {
    "detailReduction": {
      "type": "string",
      "enum": [
        "none",
        "light",
        "moderate",
        "strong"
      ]
    },
    "retrievalEligibility": {
      "type": "string",
      "enum": [
        "normal",
        "reduced_detail",
        "archive_only",
        "blocked_pending_review"
      ]
    },
    "update": {
      "type": "object",
      "required": [
        "memory_id",
        "new_confidence",
        "new_decay_state",
        "detail_reduction",
        "retrieval_eligibility",
        "reason",
        "requires_review",
        "evidence_refs"
      ],
      "additionalProperties": false,
      "properties": {
        "memory_id": {
          "type": "string",
          "minLength": 1
        },
        "new_confidence": {
          "$ref": "./candidate-memory.schema.json#/$defs/score"
        },
        "new_decay_state": {
          "$ref": "./semantic-memory.schema.json#/$defs/decayState"
        },
        "detail_reduction": {
          "$ref": "#/$defs/detailReduction"
        },
        "retrieval_eligibility": {
          "$ref": "#/$defs/retrievalEligibility"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "requires_review": {
          "type": "boolean"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "./candidate-memory.schema.json#/$defs/evidenceRef"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "requires_review": {
                "const": true
              }
            }
          },
          "then": {
            "properties": {
              "retrieval_eligibility": {
                "enum": [
                  "reduced_detail",
                  "archive_only",
                  "blocked_pending_review"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "new_decay_state": {
                "const": "archived"
              }
            }
          },
          "then": {
            "properties": {
              "retrieval_eligibility": {
                "enum": [
                  "archive_only",
                  "blocked_pending_review"
                ]
              },
              "detail_reduction": {
                "enum": [
                  "moderate",
                  "strong"
                ]
              }
            }
          }
        }
      ]
    }
  }
}
