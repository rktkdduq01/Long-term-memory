{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-term-memory.local/schemas/approval-review.schema.json",
  "title": "Approval Review",
  "type": "object",
  "required": [
    "generated_at",
    "repo_scope",
    "recommendations",
    "warnings"
  ],
  "additionalProperties": false,
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "repo_scope": {
      "type": "string",
      "minLength": 1
    },
    "recommendations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recommendation"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "recommendedAction": {
      "type": "string",
      "enum": [
        "approve",
        "reject",
        "needs_review"
      ]
    },
    "recommendation": {
      "type": "object",
      "required": [
        "candidate_id",
        "recommended_action",
        "reason",
        "confidence",
        "conflict_memory_ids",
        "evidence_refs",
        "persistence_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "recommended_action": {
          "$ref": "#/$defs/recommendedAction"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "./memory.schema.json#/$defs/score"
        },
        "conflict_memory_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "./memory.schema.json#/$defs/evidenceRef"
          }
        },
        "persistence_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
