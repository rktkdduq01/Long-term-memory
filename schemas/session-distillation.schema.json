{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-term-memory.local/schemas/session-distillation.schema.json",
  "title": "Session Distillation",
  "type": "object",
  "required": [
    "session_summary",
    "key_takeaways",
    "durable_candidates",
    "unresolved_items"
  ],
  "additionalProperties": false,
  "properties": {
    "session_summary": {
      "$ref": "#/$defs/sessionSummary"
    },
    "key_takeaways": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/keyTakeaway"
      }
    },
    "durable_candidates": {
      "type": "array",
      "items": {
        "$ref": "./candidate-memory.schema.json"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unresolvedItem"
      }
    }
  },
  "$defs": {
    "sessionSummary": {
      "type": "object",
      "required": [
        "summary",
        "confidence",
        "evidence_refs"
      ],
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "./candidate-memory.schema.json#/$defs/score"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "./candidate-memory.schema.json#/$defs/evidenceRef"
          }
        }
      }
    },
    "keyTakeaway": {
      "type": "object",
      "required": [
        "takeaway_id",
        "gist",
        "confidence",
        "evidence_refs"
      ],
      "additionalProperties": false,
      "properties": {
        "takeaway_id": {
          "type": "string",
          "minLength": 1
        },
        "gist": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "./candidate-memory.schema.json#/$defs/score"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "./candidate-memory.schema.json#/$defs/evidenceRef"
          }
        }
      }
    },
    "unresolvedItem": {
      "type": "object",
      "required": [
        "item_id",
        "type",
        "gist",
        "scope_type",
        "scope_value",
        "confidence",
        "evidence_refs",
        "suggested_follow_up"
      ],
      "additionalProperties": false,
      "properties": {
        "item_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "open_question",
            "risk",
            "conflict",
            "missing_evidence",
            "follow_up"
          ]
        },
        "gist": {
          "type": "string",
          "minLength": 1
        },
        "scope_type": {
          "$ref": "./candidate-memory.schema.json#/$defs/scopeType"
        },
        "scope_value": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "./candidate-memory.schema.json#/$defs/score"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "./candidate-memory.schema.json#/$defs/evidenceRef"
          }
        },
        "suggested_follow_up": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
