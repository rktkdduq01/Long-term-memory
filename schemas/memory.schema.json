{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-term-memory.local/schemas/memory.schema.json",
  "title": "Memory",
  "type": "object",
  "required": [
    "memory_id",
    "kind",
    "memory_type",
    "gist",
    "scope_type",
    "scope_value",
    "confidence",
    "importance",
    "status",
    "created_at",
    "updated_at",
    "evidence_refs",
    "source_trust_level",
    "sensitivity",
    "supersedes",
    "superseded_by",
    "conflicts"
  ],
  "additionalProperties": false,
  "properties": {
    "memory_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "$ref": "#/$defs/memoryKind"
    },
    "memory_type": {
      "$ref": "#/$defs/memoryType"
    },
    "gist": {
      "type": "string",
      "minLength": 1
    },
    "scope_type": {
      "$ref": "#/$defs/scopeType"
    },
    "scope_value": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "$ref": "#/$defs/score"
    },
    "importance": {
      "$ref": "#/$defs/score"
    },
    "status": {
      "$ref": "#/$defs/memoryStatus"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidenceRef"
      }
    },
    "source_trust_level": {
      "$ref": "#/$defs/sourceTrustLevel"
    },
    "sensitivity": {
      "$ref": "#/$defs/sensitivity"
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "superseded_by": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "conflicts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conflictRef"
      }
    }
  },
  "$defs": {
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "memoryKind": {
      "type": "string",
      "enum": [
        "semantic",
        "episodic",
        "procedural",
        "project"
      ]
    },
    "memoryType": {
      "type": "string",
      "enum": [
        "user_preference",
        "repo_rule",
        "project_constraint",
        "failure_lesson",
        "success_pattern",
        "procedure",
        "approval_boundary",
        "unresolved_risk",
        "session_fact"
      ]
    },
    "scopeType": {
      "type": "string",
      "enum": [
        "global_user",
        "repo",
        "branch",
        "directory",
        "file",
        "task_type",
        "session"
      ]
    },
    "memoryStatus": {
      "type": "string",
      "enum": [
        "active",
        "superseded",
        "archived",
        "deprecated"
      ]
    },
    "sourceType": {
      "type": "string",
      "enum": [
        "user_message",
        "agent_message",
        "tool_result",
        "file",
        "test_result",
        "ci_log",
        "repo_config",
        "manual_review",
        "session_event"
      ]
    },
    "sourceTrustLevel": {
      "type": "string",
      "enum": [
        "trusted",
        "partially_trusted",
        "untrusted"
      ]
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "sensitive",
        "restricted"
      ]
    },
    "factOrInference": {
      "type": "string",
      "enum": [
        "fact",
        "inference"
      ]
    },
    "evidenceRef": {
      "type": "object",
      "required": [
        "source_type",
        "source_id",
        "quote_or_summary",
        "observed_at",
        "trust_level"
      ],
      "additionalProperties": false,
      "properties": {
        "source_type": {
          "$ref": "#/$defs/sourceType"
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "quote_or_summary": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "trust_level": {
          "$ref": "#/$defs/sourceTrustLevel"
        }
      }
    },
    "conflictRef": {
      "type": "object",
      "required": [
        "memory_id",
        "conflict_type",
        "note",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "memory_id": {
          "type": "string",
          "minLength": 1
        },
        "conflict_type": {
          "type": "string",
          "enum": [
            "duplicate",
            "scope_overlap",
            "direct_conflict",
            "supersedes"
          ]
        },
        "note": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "#/$defs/score"
        }
      }
    }
  }
}
