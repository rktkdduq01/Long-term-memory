{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-term-memory.local/schemas/episodic-memory.schema.json",
  "title": "Episodic Memory",
  "type": "object",
  "required": [
    "episode_id",
    "event_type",
    "summary",
    "status",
    "scope_type",
    "scope_value",
    "created_at",
    "related_files",
    "evidence_refs",
    "linked_memories"
  ],
  "additionalProperties": false,
  "properties": {
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "$ref": "#/$defs/eventType"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "scope_type": {
      "$ref": "./candidate-memory.schema.json#/$defs/scopeType"
    },
    "scope_value": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "related_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./candidate-memory.schema.json#/$defs/evidenceRef"
      }
    },
    "linked_memories": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "observed",
        "archived",
        "deleted"
      ]
    },
    "eventType": {
      "type": "string",
      "enum": [
        "ci_failure",
        "user_request",
        "assistant_action",
        "tool_run",
        "validation_result",
        "error",
        "review_feedback",
        "decision",
        "other"
      ]
    }
  }
}
