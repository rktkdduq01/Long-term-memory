{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-term-memory.local/schemas/conflict-action.schema.json",
  "title": "Conflict Action",
  "type": "object",
  "required": [
    "actions"
  ],
  "additionalProperties": false,
  "properties": {
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      }
    }
  },
  "$defs": {
    "actionType": {
      "type": "string",
      "enum": [
        "merge",
        "refine_scope",
        "deprecate_old",
        "keep_both",
        "flag_conflict"
      ]
    },
    "conflictType": {
      "type": "string",
      "enum": [
        "duplicate",
        "partial_overlap",
        "scope_narrowing",
        "direct_conflict",
        "stale_memory",
        "insufficient_evidence"
      ]
    },
    "semanticStatus": {
      "type": "string",
      "enum": [
        "promoted",
        "stable",
        "fading",
        "archived",
        "deprecated"
      ]
    },
    "patch": {
      "type": "object",
      "required": [
        "new_gist",
        "new_scope_type",
        "new_scope_value",
        "new_status",
        "deprecated_memory_id",
        "replacement_memory_id",
        "evidence_refs_to_add"
      ],
      "additionalProperties": false,
      "properties": {
        "new_gist": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "new_scope_type": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "global_user",
            "repo",
            "branch",
            "directory",
            "file",
            "task_type",
            "session",
            null
          ]
        },
        "new_scope_value": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "new_status": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "promoted",
            "stable",
            "fading",
            "archived",
            "deprecated",
            null
          ]
        },
        "deprecated_memory_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "replacement_memory_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "evidence_refs_to_add": {
          "type": "array",
          "items": {
            "$ref": "./candidate-memory.schema.json#/$defs/evidenceRef"
          }
        }
      }
    },
    "scopeType": {
      "type": "string",
      "enum": [
        "global_user",
        "repo",
        "branch",
        "directory",
        "file",
        "task_type",
        "session"
      ]
    },
    "action": {
      "type": "object",
      "required": [
        "action",
        "existing_memory_id",
        "new_candidate_id",
        "conflict_type",
        "patch",
        "reason",
        "requires_human_review"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "$ref": "#/$defs/actionType"
        },
        "existing_memory_id": {
          "type": "string",
          "minLength": 1
        },
        "new_candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "conflict_type": {
          "$ref": "#/$defs/conflictType"
        },
        "patch": {
          "$ref": "#/$defs/patch"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "requires_human_review": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "refine_scope"
              }
            }
          },
          "then": {
            "properties": {
              "patch": {
                "properties": {
                  "new_scope_type": {
                    "$ref": "#/$defs/scopeType"
                  },
                  "new_scope_value": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "deprecate_old"
              }
            }
          },
          "then": {
            "properties": {
              "patch": {
                "properties": {
                  "new_status": {
                    "const": "deprecated"
                  },
                  "deprecated_memory_id": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "enum": [
                  "keep_both",
                  "flag_conflict"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "patch": {
                "properties": {
                  "new_status": {
                    "type": "null"
                  },
                  "deprecated_memory_id": {
                    "type": "null"
                  },
                  "replacement_memory_id": {
                    "type": "null"
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
