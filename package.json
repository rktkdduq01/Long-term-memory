{
  "name": "long-term-memory-harness",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types runtime/runtime.test.ts tests/repository.test.ts",
    "validate": "python3 scripts/validate_memory_harness.py && npm run typecheck && npm test && npm run memory:validate",
    "memory:briefing": "node --experimental-strip-types runtime/cli/memoryBriefing.ts",
    "memory:search": "node --experimental-strip-types runtime/cli/memorySearch.ts",
    "memory:candidates": "node --experimental-strip-types runtime/cli/memoryCandidates.ts",
    "memory:approve": "node --experimental-strip-types runtime/cli/memoryApprove.ts",
    "memory:reject": "node --experimental-strip-types runtime/cli/memoryReject.ts",
    "memory:validate": "node --experimental-strip-types runtime/cli/memoryValidate.ts"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3"
  }
}
